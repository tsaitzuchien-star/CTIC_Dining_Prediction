@echo off
:: 設定編碼為 UTF-8，防止中文變亂碼
chcp 65001 >nul

:: 設定視窗標題
title 中創園區 - 早盤自動排程引擎

:: 切換到這個 .bat 檔所在的資料夾 (終極防呆，確保絕對找得到 Python 檔)
cd /d "%~dp0"

echo =====================================================
echo   啟動中創園區早盤自動排程引擎...
echo =====================================================

:: 執行 Python 程式
python auto_scheduler.py

:: 如果程式意外關閉，讓視窗停住不要閃退，方便我們看錯誤訊息
pause